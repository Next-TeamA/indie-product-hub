# ============================================================
# LaunchPad Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Supabase (https://supabase.com/dashboard/project/settings/api)
SUPABASE_URL=
SUPABASE_KEY=                    # anon key
SUPABASE_SERVICE_ROLE_KEY=       # service role key
SUPABASE_JWT_SECRET=             # JWT Secret (Settings > API > JWT Secret)

# App
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# AI (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Token encryption
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# X / Twitter (https://developer.x.com > App > OAuth 2.0)
X_CLIENT_ID=
X_CLIENT_SECRET=

# Threads / Meta (https://developers.facebook.com > App > Basic)
THREADS_APP_ID=
THREADS_CLIENT_SECRET=

# GitHub (https://github.com/settings/developers > OAuth Apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=           # Any random string for webhook HMAC

# Vercel (https://vercel.com/account/integrations > Create Integration)
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
VERCEL_WEBHOOK_SECRET=           # Shown once when creating webhook

# Railway (Railway Dashboard > Workspace Settings > Developer > OAuth App)
RAILWAY_CLIENT_ID=
RAILWAY_CLIENT_SECRET=
